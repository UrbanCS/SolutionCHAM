<?xml version="1.0" encoding="utf-8"?>
<config>
	<fieldset name="permissions" label="JCONFIG_PERMISSIONS_LABEL">
		<field
			name="rules"
			type="rules"
			label="JCONFIG_PERMISSIONS_LABEL"
			filter="rules"
			validate="rules"
			component="com_instructor_billing"
			section="component"
		/>
	</fieldset>
	<fieldset name="billing" label="COM_INSTRUCTOR_BILLING_CONFIG_BILLING_LABEL">
		<field name="invoice_prefix" type="text" default="CHAM" label="COM_INSTRUCTOR_BILLING_CONFIG_INVOICE_PREFIX" />
		<field name="tax_enabled" type="radio" default="0" label="COM_INSTRUCTOR_BILLING_CONFIG_TAX_ENABLED" class="switcher">
			<option value="0">JNO</option>
			<option value="1">JYES</option>
		</field>
		<field name="tax_rate" type="number" default="0" label="COM_INSTRUCTOR_BILLING_CONFIG_TAX_RATE" step="0.001" min="0" />
		<field name="default_hourly_rate" type="number" default="0" label="COM_INSTRUCTOR_BILLING_CONFIG_DEFAULT_RATE" step="0.01" min="0" />
		<field name="display_timezone" type="text" default="America/Toronto" label="COM_INSTRUCTOR_BILLING_CONFIG_DISPLAY_TIMEZONE" description="COM_INSTRUCTOR_BILLING_CONFIG_DISPLAY_TIMEZONE_DESC" />
	</fieldset>
	<fieldset name="sage" label="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_LABEL">
		<field name="sage_enabled" type="radio" default="0" label="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_ENABLED" class="switcher">
			<option value="0">JNO</option>
			<option value="1">JYES</option>
		</field>
		<field name="sage_client_id" type="text" default="" label="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_CLIENT_ID" />
		<field name="sage_client_secret" type="password" default="" label="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_CLIENT_SECRET" />
		<field name="sage_redirect_uri" type="url" default="" label="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_REDIRECT_URI" />
		<field name="sage_scope" type="text" default="full_access" label="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_SCOPE" />
		<field name="sage_api_base" type="url" default="https://api.accounting.sage.com/v3.1" label="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_API_BASE" />
		<field name="sage_business_id" type="text" default="" label="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_BUSINESS_ID" description="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_BUSINESS_ID_DESC" />
		<field name="sage_document_type" type="list" default="purchase_invoice" label="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_DOCUMENT_TYPE">
			<option value="purchase_invoice">COM_INSTRUCTOR_BILLING_CONFIG_SAGE_DOCUMENT_PURCHASE</option>
			<option value="sales_invoice">COM_INSTRUCTOR_BILLING_CONFIG_SAGE_DOCUMENT_SALES</option>
		</field>
		<field name="sage_contact_type" type="text" default="VENDOR" label="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_CONTACT_TYPE" description="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_CONTACT_TYPE_DESC" />
		<field name="sage_default_contact_id" type="text" default="" label="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_DEFAULT_CONTACT_ID" description="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_DEFAULT_CONTACT_ID_DESC" />
		<field name="sage_ledger_account_id" type="text" default="" label="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_LEDGER_ACCOUNT_ID" description="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_LEDGER_ACCOUNT_ID_DESC" />
		<field name="sage_tax_rate_id" type="text" default="" label="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_TAX_RATE_ID" description="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_TAX_RATE_ID_DESC" />
		<field name="sage_due_days" type="number" default="0" label="COM_INSTRUCTOR_BILLING_CONFIG_SAGE_DUE_DAYS" min="0" step="1" />
	</fieldset>
</config>
